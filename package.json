{
  "name": "mysite",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:move": "npm run dev -w @mysite/move",
    "dev:home": "npm run dev -w @mysite/home",
    "build": "turbo run build",
    "build:move": "npm run build -w @mysite/move",
    "build:home": "npm run build -w @mysite/home",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.8.15"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
