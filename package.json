{
  "name": "eve-frontier-space",
  "version": "1.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:move": "npm run dev -w @eve-frontier-space/move",
    "dev:home": "npm run dev -w @eve-frontier-space/home",
    "dev:finance": "npm run dev -w @eve-frontier-space/finance",
    "build": "turbo run build && node scripts/combine-dist.mjs",
    "build:move": "npm run build -w @eve-frontier-space/move",
    "build:home": "npm run build -w @eve-frontier-space/home",
    "build:finance": "npm run build -w @eve-frontier-space/finance",
    "typecheck": "turbo run typecheck",
    "resize-images": "node packages/assets/resize.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "turbo": "^2.8.15"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
