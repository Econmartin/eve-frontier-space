RewriteEngine On
RewriteBase /

# Let Apache handle the /move sub-app directory directly
RewriteRule ^move(/.*)?$ - [L]

# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# SPA fallback for home app routes
RewriteRule . /index.html [L]
